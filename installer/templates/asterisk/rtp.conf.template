; rSwitch RTP Configuration
; Optimized for high call volume (1000+ concurrent calls)

[general]
; Wide port range: 20,000 ports = supports 10,000 concurrent RTP streams
rtpstart=10000
rtpend=30000

; Security: enforce symmetric RTP
strictrtp=yes

; Performance: disable ICE/STUN (not needed for server-to-server)
icesupport=no
stunaddr=
