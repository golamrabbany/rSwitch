; rSwitch RTP Configuration
; Optimized for high call volume (3000+ concurrent calls)

[general]
; Port range: 30,000 ports = 7,500 concurrent calls (4 ports per call: RTP+RTCP each direction).
; Sized for 1000-1200 concurrent with margin for stuck-port leaks.
rtpstart=10000
rtpend=40000

; Security: enforce symmetric RTP
strictrtp=yes

; Performance: disable ICE/STUN (not needed for server-to-server)
icesupport=no
stunaddr=

; Performance: reduce DTMF detection overhead
dtmftimeout=3000
